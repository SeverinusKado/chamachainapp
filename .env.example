# Solana cluster the frontend talks to (devnet | mainnet-beta | localnet)
VITE_CLUSTER=devnet

# Base URL of YOUR on-ramp backend proxy (holds the Kotani Pay secret key and
# handles webhooks). Leave unset to keep the fiat deposit flow in simulated mode
# for every country. When set, mobile-money deposits in Kenya/Uganda/Ghana/
# Nigeria route to Kotani Pay via this backend.
# Example: https://api.chamachain.app
# VITE_ONRAMP_API_BASE=
